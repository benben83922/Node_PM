# ===================================================================
# 區塊一：OpenClaw 映像設定
# ===================================================================
# OpenClaw Docker 映像版本（通常不需要更改）
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:2026.5.20

# OpenClaw 設定目錄（請替換 YOUR_USERNAME，必須是絕對路徑）
OPENCLAW_CONFIG_DIR=/home/YOUR_USERNAME/.openclaw


# ===================================================================
# 區塊二：Obsidian Vault 路徑
# ===================================================================
# Vault 在 WSL/Linux 中的路徑（建議使用原生路徑，避免 /mnt/c/... 問題）
VAULT_PATH=/home/YOUR_USERNAME/Obsidian_Vault


# ===================================================================
# 區塊三：推論模型設定（OpenAI-compatible endpoint）
# ===================================================================
# API Key（OpenRouter / OpenAI / 其他相容服務）
API_KEY=sk-or-v1-xxxxx

# 模型端點 URL（預設為 OpenRouter）
API_URL=https://openrouter.ai/api/v1

# 指定使用的 AI 模型名稱
MODEL=anthropic/claude-3.5-sonnet


# ===================================================================
# 區塊四：Discord Bot 設定
# ===================================================================
# Discord Bot Token（從 Discord Developer Portal 取得）
DISCORD_BOT_TOKEN=MTU...

# Discord 伺服器 ID（右鍵伺服器圖示 > 複製伺服器 ID）
DISCORD_SERVER_ID=123456789012345678

# 你的 Discord 用戶 ID（右鍵個人頭像 > 複製用戶 ID）
DISCORD_USER_ID=123456789012345678

# Bot 是否需要 @mention 才回應（1 = 需要，0 = 不需要）
DISCORD_REQUIRE_MENTION=1


# ===================================================================
# 區塊五：其他設定
# ===================================================================
LOG_LEVEL=info
